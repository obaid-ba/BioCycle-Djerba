# ---- Application ----
PROJECT_NAME="BioCycle Djerba"
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=biocycle
POSTGRES_PASSWORD=biocycle
POSTGRES_DB=biocycle

# ---- CORS (frontend dev server) ----
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- Auth (Phase 1) ----
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Initial admin (seeded via: python -m scripts.seed_admin) ----
# NOTE: use a real TLD — login validates with EmailStr, which rejects reserved
# TLDs like `.local`, so an admin@…​.local would be seeded but unable to log in.
FIRST_SUPERUSER_EMAIL=admin@biocycle.tn
FIRST_SUPERUSER_PASSWORD=changeme123
FIRST_SUPERUSER_NAME="BioCycle Admin"

# ---- MQTT (Phase 4) — disabled: Smart Bins / IoT telemetry removed from product ----
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=biocycle/+/telemetry

# ---- AI service integration (Phase 5) ----
AI_SERVICE_BASE_URL=http://localhost:9000
AI_SERVICE_TIMEOUT_SECONDS=10

# ---- Alert thresholds (Phase 6) ----
ALERT_FILL_THRESHOLD=85
ALERT_FILL_CRITICAL=95
ALERT_BATTERY_THRESHOLD=15
